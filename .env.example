# Required: Gemini API key for DADDU's AI features
GEMINI_API_KEY="your-gemini-api-key-here"

# Optional: For split deployment (frontend on Vercel/Netlify + backend elsewhere)
# Set these in your Vercel/Netlify project dashboard when deploying the frontend.
# If deploying as full-stack (e.g., Railway), leave these blank — the frontend
# will connect to the same origin automatically.
#
# VITE_API_URL="https://daddu-backend.railway.app"
# VITE_WS_URL="wss://daddu-backend.railway.app/ws-live"
